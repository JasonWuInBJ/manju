generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                    String        @id @default(uuid())
  title                 String
  novelText             String?
  synopsis              String?
  defaultNegativePrompt String?       // 全局默认负面提示词
  style                 String?       @default("cel-shaded anime style")
  model                 String?       @default("glm-5")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  scripts               Script[]
  characters            Character[]
  scenes                Scene[]
  props                 Prop[]
  promptConfigs         PromptConfig[]
  episodes              Episode[]
  videos                Video[]
  stylePresets          StylePreset[]
}

model Script {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode   Int      @default(1)
  title     String
  novelText String?  // 每集对应的小说原文
  content   String
  summary   String?
  shots     Shot[]
  scenes    Scene[]
  videos    Video[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shot {
  id               String  @id @default(uuid())
  scriptId         String
  script           Script  @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  order            Int
  duration         Int     // 秒数，AI生成
  cameraShotType   String  // wide/medium/close/extreme-close
  cameraMovement   String  // static/slow_push_in/slow_pull_out/pan_left/pan_right/tilt_up/tilt_down/dynamic_follow/slight_handheld_shake/orbit
  sceneSetting     String  // 中文场景描述，供用户阅读
  characterAction  String? // 中文角色动作描述，可选
  visualPrompt     String  // 英文结构化提示词，给视频模型用
  negativePrompt   String? // 镜头级负面提示词，可选
  refCharacterIds  String? // JSON数组，引用的角色ID，可选
  refPropIds       String? // JSON数组，引用的道具ID，可选
  refSceneIds      String? // JSON数组，引用的场景ID，可选
  audio            String  // 中文，对白/音效
}

model Character {
  id               String  @id @default(uuid())
  projectId        String
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  role             String
  description      String
  prompt           String?
  imageUrl         String?
  imageTaskId      String?  // 图片生成任务 ID（用于恢复轮询）
  fourViewImageUrl String?
  characterVideoUrl String?  // 角色视频 URL（用于上传角色）
  characterVideoTaskId String?  // 视频生成任务 ID（用于恢复轮询）
  soraCharacterId  String?   // Sora 角色 ID（上传后获得）
  seed             Int?
  // 换装支持（平级关系）
  characterGroupId String?  // 同一角色不同版本共享此 ID
  costumeName      String?  // 装扮名称，如"日常便服"；原版为 null
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Scene {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptId    String?
  script      Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  name        String
  description String
  time           String   @default("day")
  mood           String   @default("neutral")
  weather        String   @default("Clear")
  prompt         String?
  negativePrompt String?
  imageUrl       String?
  imageTaskId    String?  // 用于恢复图片生成轮询
  // 详细场景信息
  location        String?  // 空间位置，如"EXT-第108层天桥-栏杆旁"
  region          String?  // 地域坐标，如"亚洲-中国-新九龙"
  environmentType String?  // 环境类型，如"城市/室内/自然"
  era             String?  // 年代坐标，如"未来-中国"
  season          String?  // 季节，如"夏季"
  sceneFunction   String?  // 场景功能，如"开场介绍;起(背景铺垫)"
  spaceLayout     String?  // 空间区域划分
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromptConfig {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // 'script', 'character', 'scene', 'scene_extract', 'storyboard', 'video', 'image', 'prop', 'prop_extract'
  name      String   // 配置名称，如'默认剧本生成'
  systemPrompt String
  userPrompt String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Episode {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  scriptIds   String?  // JSON 数组: ["script-id-1", "script-id-2"]
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id                   String   @id @default(uuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeId            String?
  episode              Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  scriptId             String?
  script               Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  name                 String?

  // 排序
  order                Int      @default(0)
  startTime            Float?   // 秒，可选
  endTime              Float?   // 秒，可选

  // 生成参数
  prompt               String?
  selectedCharacterIds String?  // JSON 数组
  selectedSceneIds     String?  // JSON 数组
  selectedShotIds      String?  // JSON 数组

  // 资产
  assets               VideoAsset[]

  // 兼容旧数据（后续版本清理）
  compositeImageUrl     String?
  compositeImageTaskId  String?
  videoUrl              String?
  videoTaskId           String?
  videoPrompt           String?
  storyboardImageBase64 String?
  storyboardUrl         String?
  storyboardTaskId      String?
  layoutType            String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model VideoAsset {
  id           String   @id @default(uuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  type         String   // "composite_image" | "video"
  url          String?
  taskId       String?  // 轮询任务 ID
  duration     Int?     // 5 | 10 | 15
  aspectRatio  String?  // "16:9" | "9:16" | "1:1"
  prompt       String?  // 生成时使用的 prompt
  version      Int      @default(1)
  createdAt    DateTime @default(now())
}

model Prop {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String
  prompt      String?
  imageUrl    String?
  imageTaskId String?  // 生图任务 ID（用于恢复轮询）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StylePreset {
  id          String   @id @default(uuid())
  name        String   // 显示名称
  keywords    String   // 英文关键词
  category    String   // 'popular' | 'artistic' | '3d'
  icon        String   // emoji 图标
  description String   // 中文描述
  isDefault   Boolean  @default(false) // 系统预设标识
  order       Int      @default(0) // 排序权重
  projectId   String?  // null=全局预设，非null=项目自定义
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, category])
}

model GlobalConfig {
  id               String   @id @default("default")
  // 智谱 AI 配置
  glmApiKey        String?
  glmApiUrl        String?  @default("https://open.bigmodel.cn/api/paas/v4/chat/completions")
  // Anthropic 配置
  anthropicApiKey  String?
  anthropicApiUrl  String?  @default("https://api.anthropic.com")
  // RunningHub 配置（生图、生视频）
  runningHubApiKey String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
